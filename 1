  <div class="admin-header">
    <span style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--accent);display:block;margin-bottom:0.6rem;">Admin Panel</span>
    <h2 class="admin-title">Manage Projects</h2>
  </div>

  <div class="admin-grid">
    <!-- Form -->
    <div class="admin-form-wrap">
      <div class="admin-form-title">// Add New Project</div>
      <div class="admin-form">
        <div class="fgroup">
          <label class="flabel">Project Name *</label>
          <input class="finput" id="proj-name" type="text" placeholder="e.g. E-Commerce Website QA"/>
        </div>
        <div class="fgroup">
          <label class="flabel">Description *</label>
          <textarea class="finput" id="proj-desc" style="min-height:88px;" placeholder="Brief description of what was tested and findings..."></textarea>
        </div>
        <div class="fgroup">
          <label class="flabel">Project Image</label>
          <div class="file-upload">
            <input type="file" id="proj-img" accept="image/*" onchange="handleImg(this)"/>
            <div class="file-upload-icon">🖼️</div>
            <div class="file-upload-text">Click to upload image (JPG, PNG, WebP)</div>
            <div class="file-name-ok" id="img-name-ok"></div>
          </div>
        </div>
        <div class="fgroup">
          <label class="flabel">Project File (PDF / Excel / ZIP)</label>
          <div class="file-upload">
            <input type="file" id="proj-file" accept=".pdf,.xlsx,.xls,.zip,.doc,.docx,.csv" onchange="handleFile(this)"/>
            <div class="file-upload-icon">📎</div>
            <div class="file-upload-text">Click to upload file</div>
            <div class="file-name-ok" id="file-name-ok"></div>
          </div>
        </div>
        <button class="btn btn-p" style="width:100%;justify-content:center;cursor:none;" onclick="addProject()">Add Project →</button>
        <div class="form-msg" id="form-msg"></div>
      </div>
    </div>

    <!-- List -->
    <div>
      <div class="admin-list-title">// Projects (<span id="proj-count">0</span>)</div>
      <div class="admin-projects-list" id="admin-list">
        <div class="admin-empty" id="admin-empty">No projects added yet.</div>
      </div>
    </div>
  </div>
