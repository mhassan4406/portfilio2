<script>
// Cursor
const cur=document.getElementById('cursor'),ring=document.getElementById('cursor-ring');
document.addEventListener('mousemove',e=>{
  cur.style.left=e.clientX+'px';cur.style.top=e.clientY+'px';
  ring.style.left=e.clientX+'px';ring.style.top=e.clientY+'px';
});

// Scroll reveal
const ro=new IntersectionObserver(entries=>{
  entries.forEach((e,i)=>{if(e.isIntersecting)setTimeout(()=>e.target.classList.add('on'),i*70);});
},{threshold:0.08});
document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));

// ---- State ----
let projects=JSON.parse(localStorage.getItem('mh_projects')||'[]');
let _imgData=null,_fileData=null,_fileName=null;

function save(){localStorage.setItem('mh_projects',JSON.stringify(projects));}

function handleImg(input){
  const f=input.files[0]; if(!f)return;
  document.getElementById('img-name-ok').textContent='✓ '+f.name;
  const r=new FileReader(); r.onload=e=>_imgData=e.target.result; r.readAsDataURL(f);
}
function handleFile(input){
  const f=input.files[0]; if(!f)return;
  _fileName=f.name;
  document.getElementById('file-name-ok').textContent='✓ '+f.name;
  const r=new FileReader(); r.onload=e=>_fileData=e.target.result; r.readAsDataURL(f);
}

function addProject(){
  const name=document.getElementById('proj-name').value.trim();
  const desc=document.getElementById('proj-desc').value.trim();
  const msg=document.getElementById('form-msg');
  if(!name||!desc){msg.style.color='#ff5050';msg.textContent='⚠ Name and description are required.';return;}
  projects.unshift({id:Date.now(),name,desc,img:_imgData,fileData:_fileData,fileName:_fileName});
  save(); renderAdmin(); renderProjects();
  document.getElementById('proj-name').value='';
  document.getElementById('proj-desc').value='';
  document.getElementById('proj-img').value='';
  document.getElementById('proj-file').value='';
  document.getElementById('img-name-ok').textContent='';
  document.getElementById('file-name-ok').textContent='';
  _imgData=null;_fileData=null;_fileName=null;
  msg.style.color='#4ade80';msg.textContent='✓ Project added successfully!';
  setTimeout(()=>msg.textContent='',3000);
}

function deleteProject(id){
  if(!confirm('Delete this project?'))return;
  projects=projects.filter(p=>p.id!==id);
  save(); renderAdmin(); renderProjects();
}

function renderAdmin(){
  const list=document.getElementById('admin-list');
  document.getElementById('proj-count').textContent=projects.length;
  if(!projects.length){list.innerHTML='<div class="admin-empty">No projects added yet.</div>';return;}
  list.innerHTML=projects.map(p=>`
    <div class="admin-proj-item">
      <div class="admin-proj-thumb">${p.img?`<img src="${p.img}" alt=""/>`:'📁'}</div>
      <div class="admin-proj-info">
        <div class="admin-proj-name">${p.name}</div>
        <div class="admin-proj-subdesc">${p.desc}</div>
      </div>
      <button class="admin-proj-del" onclick="deleteProject(${p.id})">Delete</button>
    </div>
  `).join('');
}

function renderProjects(){
  const grid=document.getElementById('projects-grid');
  if(!projects.length){
    grid.innerHTML='<div class="proj-empty" id="projects-empty">// No projects yet<br/>Click "Manage Projects" to add your first project</div>';
    return;
  }
  grid.innerHTML=projects.map(p=>`
    <div class="proj-card">
      ${p.img?`<img class="proj-img" src="${p.img}" alt="${p.name}"/>`:'<div class="proj-img-placeholder">📁</div>'}
      <div class="proj-body">
        <div class="proj-title">${p.name}</div>
        <div class="proj-desc">${p.desc}</div>
        <div class="proj-footer">
          ${p.fileData?`<a class="proj-link" href="${p.fileData}" download="${p.fileName}">⬇ Download File</a>`:''}
        </div>
      </div>
    </div>
  `).join('');
}

function openAdmin(){
  document.getElementById('main-page').classList.add('hidden');
  document.getElementById('admin-page').classList.add('active');
  renderAdmin(); window.scrollTo(0,0);
}
function closeAdmin(){
  document.getElementById('admin-page').classList.remove('active');
  document.getElementById('main-page').classList.remove('hidden');
  window.scrollTo(0,0);
}

renderProjects();
</script>
